<section class="cart-page page-width">
  <span class="eyebrow">Your order</span><h1 class="display-title">Cart</h1>
  {% if cart.empty? %}<div class="empty-state"><p>Your cart is currently empty.</p><a class="button" href="{{ routes.all_products_collection_url }}">Continue shopping</a></div>{% else %}
    <form action="{{ routes.cart_url }}" method="post">
      <table class="cart-table"><thead><tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th></tr></thead><tbody>{% for item in cart.items %}<tr><td><div class="cart-product">{% if item.image %}{{ item.image | image_url: width: 220 | image_tag: loading: 'lazy', alt: item.title }}{% endif %}<div><a href="{{ item.url }}"><strong>{% render 'trademark-title', title: item.product.title %}</strong></a>{% unless item.product.has_only_default_variant %}<p>{{ item.variant.title }}</p>{% endunless %}{% for property in item.properties %}{% assign property_first_character = property.first | slice: 0 %}{% unless property.last == blank or property_first_character == '_' %}<p class="cart-property"><strong>{{ property.first }}:</strong> {{ property.last }}</p>{% endunless %}{% endfor %}<a href="{{ item.url_to_remove }}">Remove</a></div></div></td><td>{{ item.final_price | money }}</td><td><label class="visually-hidden" for="Quantity-{{ forloop.index }}">Quantity for {{ item.product.title }}</label><input id="Quantity-{{ forloop.index }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0"></td><td>{{ item.final_line_price | money }}</td></tr>{% endfor %}</tbody></table>
      <div class="cart-footer"><div class="cart-summary"><p class="cart-summary__total">Subtotal: {{ cart.total_price | money }}</p><p>Taxes and shipping calculated at checkout.</p><div class="button-row"><button class="button" type="submit" name="update">Update cart</button><button class="button button--gold" type="submit" name="checkout">Checkout</button></div></div></div>
    </form>
  {% endif %}
</section>
{% schema %}{"name":"Cart","settings":[]}{% endschema %}
