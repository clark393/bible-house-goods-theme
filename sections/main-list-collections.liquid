<section class="catalog page-width"><span class="eyebrow">Explore</span><h1 class="display-title">Collections</h1><div class="collection-cards">{% for collection in collections %}{% unless collection.handle == 'frontpage' %}<a class="collection-card" href="{{ collection.url }}"><h2>{{ collection.title }}</h2><p>{{ collection.description | strip_html | truncatewords: 24 }}</p><span>Explore →</span></a>{% endunless %}{% endfor %}</div></section>
{% schema %}{"name":"Collections list","settings":[]}{% endschema %}
