<footer class="site-footer">
  <div class="page-width footer-grid">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'menu' %}
          <div {{ block.shopify_attributes }}><h2 class="footer-title">{{ block.settings.heading }}</h2><ul class="footer-links">{% for link in block.settings.menu.links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul></div>
        {% when 'newsletter' %}
          <div {{ block.shopify_attributes }}><h2 class="footer-title">{{ block.settings.heading }}</h2><p>{{ block.settings.copy }}</p>{% form 'customer', class: 'newsletter' %}<input type="hidden" name="contact[tags]" value="newsletter"><label class="visually-hidden" for="FooterEmail">Email address</label><input id="FooterEmail" type="email" name="contact[email]" placeholder="Email address" required><button type="submit">Join</button>{% if form.posted_successfully? %}<p class="form-success">Thanks—you're on the list.</p>{% endif %}{% endform %}</div>
      {% endcase %}
    {% endfor %}
  </div>
  <div class="footer-wordmark page-width">{% if settings.logo != blank %}{{ settings.logo | image_url: width: 1200 | image_tag: widths: '400,800,1200', alt: shop.name }}{% else %}<img src="{{ 'bible-house-logo.png' | asset_url }}" alt="{{ shop.name }}" width="1200" height="400">{% endif %}</div>
  <div class="page-width footer-bottom"><p>© {{ 'now' | date: '%Y' }} {{ shop.name }}</p><div>{% for policy in shop.policies %}{% if policy != blank %}<a href="{{ policy.url }}">{{ policy.title }}</a>{% endif %}{% endfor %}</div></div>
</footer>
{% schema %}
{"name":"Footer","max_blocks":4,"blocks":[{"type":"menu","name":"Menu","settings":[{"type":"text","id":"heading","label":"Heading","default":"Explore"},{"type":"link_list","id":"menu","label":"Menu","default":"footer"}]},{"type":"newsletter","name":"Newsletter","settings":[{"type":"text","id":"heading","label":"Heading","default":"Join our email list"},{"type":"textarea","id":"copy","label":"Text","default":"Get exclusive deals and early access to new products."}]}],"presets":[{"name":"Footer","blocks":[{"type":"menu","settings":{"heading":"Shop"}},{"type":"menu","settings":{"heading":"Learn"}},{"type":"menu","settings":{"heading":"Support"}},{"type":"newsletter"}]}]}
{% endschema %}
