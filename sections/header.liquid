<header class="site-header">
  <div class="page-width site-header__inner">
    <div class="site-brand">
      {% if settings.mascot != blank %}{{ settings.mascot | image_url: width: 180 | image_tag: class: 'site-brand__mascot', widths: '90,120,180', alt: '' }}{% else %}<img class="site-brand__mascot" src="{{ 'clark-whitney.png' | asset_url }}" alt="" width="180" height="180">{% endif %}
      <a href="{{ routes.root_url }}" class="site-brand__logo" aria-label="{{ shop.name }} home">
        {% if settings.logo != blank %}{{ settings.logo | image_url: width: 520 | image_tag: widths: '180,280,420,520', alt: shop.name }}{% else %}<img src="{{ 'bible-house-logo.png' | asset_url }}" alt="{{ shop.name }}" width="520" height="180">{% endif %}
      </a>
    </div>
    <nav class="desktop-nav" aria-label="Primary navigation">
      {% for link in section.settings.menu.links %}<a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title }}</a>{% endfor %}
    </nav>
    <div class="header-actions">
      <a class="header-link" href="{{ routes.search_url }}">Search</a>
      {% if shop.customer_accounts_enabled %}<a class="header-link desktop-only" href="{{ routes.account_url }}">Account</a>{% endif %}
      <a class="cart-link" href="{{ routes.cart_url }}">Cart <span aria-label="{{ cart.item_count }} items">({{ cart.item_count }})</span></a>
      <button class="menu-toggle" type="button" data-menu-toggle aria-expanded="false" aria-controls="MobileMenu">Menu</button>
    </div>
  </div>
  <nav id="MobileMenu" class="mobile-nav" aria-label="Mobile navigation" hidden>
    {% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}
  </nav>
</header>
{% schema %}
{"name":"Header","settings":[{"type":"link_list","id":"menu","label":"Menu","default":"main-menu"}]}
{% endschema %}
