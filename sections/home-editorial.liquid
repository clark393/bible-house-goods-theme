<section class="hero">
  <div class="page-width">
    <span class="eyebrow">{{ section.settings.kicker }}</span>
    <div class="hero__grid">
      <div class="hero__content">
        <h1 class="display-title">{{ section.settings.heading }}</h1>
        <div class="hero__copy">
          <p>{{ section.settings.copy }}</p>
          <a class="button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
        </div>
        <div class="hero__features">
          {% assign feature_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              {% assign feature_index = feature_index | plus: 1 %}
              <div class="hero-feature" {{ block.shopify_attributes }}>
                <div class="hero-feature__number">0{{ feature_index }}</div>
                <h3>{{ block.settings.heading }}</h3>
                <p>{{ block.settings.copy }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="hero__media">
        {% if section.settings.hero_video != blank %}
          {%- liquid
            assign video_poster = section.settings.hero_video_poster
            if video_poster == blank
              assign video_poster = section.settings.hero_image
            endif
            if video_poster == blank and section.settings.featured_product != blank
              assign video_poster = section.settings.featured_product.featured_image
            endif
            if video_poster != blank
              assign video_poster_url = video_poster | image_url: width: 2000
            endif
          -%}
          {{ section.settings.hero_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, preload: 'auto', poster: video_poster_url, image_size: '2000x' }}
        {% elsif section.settings.hero_image != blank %}
          {{ section.settings.hero_image | image_url: width: 1400 | image_tag: widths: '500,750,1000,1400', fetchpriority: 'high', alt: section.settings.hero_image.alt | default: section.settings.heading }}
        {% elsif section.settings.featured_product != blank and section.settings.featured_product.featured_image != blank %}
          {{ section.settings.featured_product.featured_image | image_url: width: 1400 | image_tag: widths: '500,750,1000,1400', fetchpriority: 'high', alt: section.settings.featured_product.title }}
        {% else %}<span>Add a Bible Band™ image</span>{% endif %}
      </div>
    </div>
  </div>
</section>

<section class="dark-section">
  <div class="page-width">
    <span class="eyebrow">How it works</span><h2 class="section-title">Simple Daily Discipleship</h2>
    <div class="steps-grid">
      <div class="step"><div class="step__number">1</div><h3>Wear It</h3><p>Put on your Bible Band™ as a daily reminder.</p></div>
      <div class="step"><div class="step__number">2</div><h3>Tap It</h3><p>Your compatible phone opens today's content.</p></div>
      <div class="step"><div class="step__number">3</div><h3>Read &amp; Pray</h3><p>Scripture, devotion, prayer, audio, and a Bible reading plan.</p></div>
    </div>
  </div>
</section>

<section class="daily-preview" aria-labelledby="daily-preview-title">
  <div class="page-width daily-preview__layout">
    <div class="daily-preview__intro">
      <span class="eyebrow">{{ section.settings.preview_kicker }}</span>
      <h2 class="display-title" id="daily-preview-title">{{ section.settings.preview_heading }}</h2>
      <p>{{ section.settings.preview_intro }}</p>
      <div class="daily-preview__included" aria-label="{{ section.settings.preview_includes_label | escape }}">
        <span>{{ section.settings.preview_scripture_label }}</span>
        <span>{{ section.settings.preview_devotion_label }}</span>
        <span>{{ section.settings.preview_prayer_label }}</span>
        <span>{{ section.settings.preview_audio_label }}</span>
        <span>{{ section.settings.preview_plan_label }}</span>
      </div>
    </div>

    <article class="daily-preview__card">
      <header class="daily-preview__card-head">
        <div>
          <span class="daily-preview__sample-label">{{ section.settings.preview_sample_label }}</span>
          <h3>{{ section.settings.preview_title }}</h3>
        </div>
        <span class="daily-preview__sun" aria-hidden="true">✦</span>
      </header>

      <div class="daily-preview__section daily-preview__scripture">
        <span class="daily-preview__label">{{ section.settings.preview_scripture_label }}</span>
        <blockquote>“{{ section.settings.preview_verse }}”</blockquote>
        <cite>{{ section.settings.preview_reference }}</cite>
      </div>

      <div class="daily-preview__section">
        <span class="daily-preview__label">{{ section.settings.preview_devotion_label }}</span>
        <p>{{ section.settings.preview_devotion }}</p>
      </div>

      <div class="daily-preview__section daily-preview__prayer">
        <span class="daily-preview__label">{{ section.settings.preview_prayer_label }}</span>
        <p>{{ section.settings.preview_prayer }}</p>
      </div>

      <footer>{{ section.settings.preview_footer }}</footer>
    </article>
  </div>
</section>

<section class="home-groups">
  <div class="page-width home-groups__inner">
    <div class="home-groups__copy">
      <span class="eyebrow">Bible Band™ Church Packs</span>
      <h2 class="display-title">Put the Word in every hand.</h2>
      <p>Equip your church, camp, youth ministry, school, retreat, or outreach with Bible Bands and a flexible church hub for Scripture, prayer guides, giving, bulletins, sermon notes, events, and next steps.</p>
      <div class="home-groups__actions">
        <a class="button button--gold" href="{{ section.settings.groups_link | default: '/pages/bible-band-church-packs' }}">Explore church packs</a>
        <a class="home-groups__text-link" href="{{ section.settings.groups_contact_link | default: '/pages/contact' }}">Ask about group pricing <span aria-hidden="true">→</span></a>
      </div>
    </div>
    <div class="home-groups__callouts" aria-label="Ways groups use the Bible Band">
      <span class="home-groups__ribbon">Made for ministry</span>
      <div class="home-groups__badge"><strong>21</strong><span>Days of Prayer</span></div>
      <ul>
        <li><span>01</span>Church-wide Scripture</li>
        <li><span>02</span>Custom Church Hub</li>
        <li><span>03</span>Camps &amp; Student Ministry</li>
        <li><span>04</span>Events &amp; Next Steps</li>
        <li><span>05</span>Group Pricing</li>
      </ul>
    </div>
  </div>
</section>

<section class="products-section">
  <div class="page-width">
    <div class="section-head"><h2 class="section-title">{{ section.settings.products_heading }}</h2><a href="{{ section.settings.collection.url | default: routes.all_products_collection_url }}">View all →</a></div>
    <div class="product-grid">
      {% assign source_collection = section.settings.collection | default: collections.all %}
      {% for product in source_collection.products limit: 4 %}{% render 'product-card', product: product %}{% else %}<p>Your products will appear here automatically.</p>{% endfor %}
    </div>
  </div>
</section>

<section class="collections-section">
  <div class="page-width">
    <span class="eyebrow">Beyond The Bible Band™</span><h2 class="section-title">More Ways To Engage Your Faith</h2>
    <div class="collection-cards">
      {% for block in section.blocks %}
        {% if block.type == 'collection' %}
          <a class="collection-card" href="{{ block.settings.collection.url | default: routes.collections_url }}" {{ block.shopify_attributes }}><h3>{{ block.settings.heading | default: block.settings.collection.title }}</h3><p>{{ block.settings.copy }}</p><span>Explore →</span></a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="quote-section"><div class="page-width"><blockquote>“{{ section.settings.quote }}”<cite>{{ section.settings.quote_cite }}</cite></blockquote></div></section>

<section class="founder"><div class="page-width founder__grid">
  <div class="founder__photo">{% if section.settings.founder_image != blank %}{{ section.settings.founder_image | image_url: width: 1200 | image_tag: widths: '500,800,1200', loading: 'lazy', alt: section.settings.founder_image.alt | default: 'Bible House Goods founder' }}{% else %}<img src="{{ 'founders.jpeg' | asset_url }}" alt="Clark Whitney and his wife" width="1200" height="900" loading="lazy">{% endif %}</div>
  <div class="founder__copy"><span class="eyebrow">Our Story</span><h2 class="section-title">{{ section.settings.founder_heading }}</h2><p>{{ section.settings.founder_copy }}</p><a class="button" href="{{ section.settings.founder_link }}">Read Our Story</a></div>
</div></section>

<section class="final-cta"><div class="page-width"><h2 class="display-title">Every Day.<br>One Tap.</h2><p>Start your wearable discipleship journey with The Bible Band™.</p><div class="button-row"><a class="button button--gold" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">Get The Bible Band™</a><a class="button button--outline" href="{{ routes.all_products_collection_url }}">Shop All</a></div></div></section>

{% schema %}
{
  "name":"Editorial homepage",
  "settings":[
    {"type":"text","id":"kicker","label":"Kicker","default":"Bible House Goods Presents · The Bible Band™"},
    {"type":"html","id":"heading","label":"Heading","default":"Keep God's<br>Word <em>Close</em>"},
    {"type":"textarea","id":"copy","label":"Intro","default":"Daily Scripture, prayer, and devotion on your wrist. One simple tap — no app, no subscription."},
    {"type":"text","id":"button_label","label":"Button label","default":"Get Your Bible Band™"},
    {"type":"url","id":"button_link","label":"Button link"},
    {"type":"url","id":"groups_link","label":"Churches and groups page"},
    {"type":"url","id":"groups_contact_link","label":"Group pricing contact link"},
    {"type":"product","id":"featured_product","label":"Bible Band product"},
    {"type":"video","id":"hero_video","label":"Hero video","info":"Recommended for animation. Upload an MP4, MOV, or WebM; it plays muted and loops automatically."},
    {"type":"image_picker","id":"hero_video_poster","label":"Video thumbnail","info":"Choose a sharp, high-resolution still image for the video while it loads. If blank, the hero image or Bible Band product image is used."},
    {"type":"image_picker","id":"hero_image","label":"Hero image"},
    {"type":"header","content":"Daily experience preview"},
    {"type":"text","id":"preview_kicker","label":"Preview kicker","default":"A Glimpse of Today"},
    {"type":"text","id":"preview_heading","label":"Preview heading","default":"One tap. A moment with God."},
    {"type":"textarea","id":"preview_intro","label":"Preview introduction","default":"Every day brings fresh Scripture, a pastor-written devotion, and a guided prayer—made to meet you in the middle of real life."},
    {"type":"text","id":"preview_includes_label","label":"Included items accessibility label","default":"Every daily experience includes"},
    {"type":"text","id":"preview_sample_label","label":"Sample label","default":"Sample Daily Experience"},
    {"type":"text","id":"preview_title","label":"Sample title","default":"Be Still in His Presence"},
    {"type":"text","id":"preview_scripture_label","label":"Scripture label","default":"Scripture"},
    {"type":"textarea","id":"preview_verse","label":"Sample verse","default":"Be still, and know that I am God."},
    {"type":"text","id":"preview_reference","label":"Verse reference","default":"Psalm 46:10"},
    {"type":"text","id":"preview_devotion_label","label":"Devotion label","default":"Devotion"},
    {"type":"textarea","id":"preview_devotion","label":"Sample devotion","default":"Stillness is not the absence of trouble. It is the choice to remember who God is while trouble is still making noise. Pause today before you rush to fix everything. Let His presence steady your heart, and trust that He is already at work in what you cannot control."},
    {"type":"text","id":"preview_prayer_label","label":"Prayer label","default":"Prayer"},
    {"type":"textarea","id":"preview_prayer","label":"Sample prayer","default":"God, quiet the noise within me. Help me release what I cannot control and rest in who You are. Make me attentive to Your presence and faithful in my next step. Amen."},
    {"type":"text","id":"preview_audio_label","label":"Audio label","default":"Audio"},
    {"type":"text","id":"preview_plan_label","label":"Reading plan label","default":"Bible Plan"},
    {"type":"text","id":"preview_footer","label":"Preview footer","default":"A fresh experience is waiting every day with The Bible Band™."},
    {"type":"text","id":"products_heading","label":"Products heading","default":"From Our Shop"},
    {"type":"collection","id":"collection","label":"Featured collection"},
    {"type":"textarea","id":"quote","label":"Quote","default":"Keep God's Word close to your heart and carry it with you daily."},
    {"type":"text","id":"quote_cite","label":"Citation","default":"Deuteronomy 11:18"},
    {"type":"image_picker","id":"founder_image","label":"Founder image"},
    {"type":"text","id":"founder_heading","label":"Founder heading","default":"Started By A Pastor, Not A Company"},
    {"type":"textarea","id":"founder_copy","label":"Founder copy","default":"Bible House Goods was started by Clark Whitney — pastor, husband, and dad — to help families keep God's Word close in the middle of everyday life. Every product is built the same way: faithful, useful, and simple."},
    {"type":"url","id":"founder_link","label":"Founder page"}
  ],
  "blocks":[
    {"type":"feature","name":"Feature","limit":3,"settings":[{"type":"text","id":"heading","label":"Heading"},{"type":"textarea","id":"copy","label":"Copy"}]},
    {"type":"collection","name":"Collection card","limit":3,"settings":[{"type":"collection","id":"collection","label":"Collection"},{"type":"text","id":"heading","label":"Custom heading"},{"type":"textarea","id":"copy","label":"Copy"}]}
  ],
  "presets":[{"name":"Editorial homepage","blocks":[{"type":"feature","settings":{"heading":"Pastor-Written","copy":"Real biblical insight. No AI. Practical encouragement for daily faith, written by a real pastor."}},{"type":"feature","settings":{"heading":"No App Needed","copy":"Just tap your phone. Scripture, prayer, devotion, audio, and a one-year Bible reading plan — all in one tap."}},{"type":"feature","settings":{"heading":"Works Everywhere","copy":"iPhone and Android compatible. A QR code backup ships in every package, just in case."}},{"type":"collection","settings":{"heading":"Devotionals & Prayer","copy":"Bible studies, prayer journals, and workbooks for deeper engagement with God's Word."}},{"type":"collection","settings":{"heading":"Printables & Resources","copy":"Downloadable guides for Bible study, family discipleship, and church leadership."}},{"type":"collection","settings":{"heading":"Faith Apparel","copy":"Christian apparel designed to spark conversations about Christ."}}]}]
}
{% endschema %}

{% stylesheet %}
  .daily-preview{padding:clamp(75px,9vw,130px) 0;background:var(--cream);color:var(--ink);overflow:hidden}
  .daily-preview__layout{display:grid;grid-template-columns:minmax(0,.85fr) minmax(420px,1.15fr);gap:clamp(50px,8vw,120px);align-items:center}
  .daily-preview__intro .display-title{max-width:720px;margin-bottom:28px;font-size:clamp(50px,6.5vw,96px)}
  .daily-preview__intro>p{max-width:590px;font-size:clamp(17px,1.5vw,20px);line-height:1.7}
  .daily-preview__included{display:flex;flex-wrap:wrap;gap:9px;margin-top:32px}
  .daily-preview__included span{padding:9px 12px;border:1px solid var(--ink);font-size:9px;font-weight:950;letter-spacing:1.2px;text-transform:uppercase}
  .daily-preview__card{position:relative;padding:clamp(30px,5vw,60px);background:#fffdf8;border:2px solid var(--ink);box-shadow:16px 16px 0 var(--gold);transform:rotate(.7deg)}
  .daily-preview__card:before{position:absolute;top:-12px;left:50%;width:110px;height:23px;background:rgba(213,197,164,.72);content:"";transform:translateX(-50%) rotate(-2deg)}
  .daily-preview__card-head{display:flex;justify-content:space-between;gap:24px;padding-bottom:28px;border-bottom:2px solid var(--ink)}
  .daily-preview__sample-label,.daily-preview__label{display:block;color:var(--rust);font-size:9px;font-weight:950;letter-spacing:1.5px;text-transform:uppercase}
  .daily-preview__card h3{margin:8px 0 0;font-family:var(--font-heading-family);font-size:clamp(30px,4vw,52px);line-height:1}
  .daily-preview__sun{color:var(--gold);font-size:34px;line-height:1}
  .daily-preview__section{padding:25px 0;border-bottom:1px solid #cfc2b1}
  .daily-preview__section p{margin:11px 0 0;font-size:15px;line-height:1.7}
  .daily-preview__scripture blockquote{margin:12px 0 5px;font-family:var(--font-heading-family);font-size:clamp(25px,3vw,37px);font-style:italic;line-height:1.15}
  .daily-preview__scripture cite{font-size:10px;font-style:normal;font-weight:950;letter-spacing:1px;text-transform:uppercase}
  .daily-preview__prayer p{font-style:italic}
  .daily-preview__card footer{padding-top:25px;font-size:10px;font-weight:900;letter-spacing:1.1px;line-height:1.5;text-transform:uppercase}
  @media(max-width:900px){.daily-preview__layout{grid-template-columns:1fr}.daily-preview__card{max-width:680px;margin-right:16px}}
  @media(max-width:640px){.daily-preview__card{padding:28px 24px;box-shadow:10px 10px 0 var(--gold)}.daily-preview__card-head{gap:12px}.daily-preview__sun{font-size:26px}}
  .home-groups{padding:clamp(75px,9vw,125px) 0;background:var(--rust);color:var(--cream);overflow:hidden}
  .home-groups__inner{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(330px,.85fr);gap:clamp(50px,8vw,120px);align-items:center}
  .home-groups .eyebrow{color:var(--gold)}
  .home-groups .display-title{max-width:850px;font-size:clamp(52px,7.4vw,108px)}
  .home-groups__copy>p{max-width:720px;margin:28px 0 0;font-size:clamp(16px,1.6vw,20px);line-height:1.65}
  .home-groups__actions{display:flex;flex-wrap:wrap;align-items:center;gap:22px;margin-top:34px}
  .home-groups__text-link{font-size:11px;font-weight:900;letter-spacing:1.4px;text-transform:uppercase;text-underline-offset:5px}
  .home-groups__callouts{position:relative;padding:36px;background:var(--cream);color:var(--ink);border:2px solid var(--ink);box-shadow:14px 14px 0 var(--gold);transform:rotate(1deg)}
  .home-groups__ribbon{display:inline-block;margin:-8px 0 25px;padding:8px 11px;background:var(--ink);color:var(--cream);font-size:9px;font-weight:900;letter-spacing:1.7px;text-transform:uppercase}
  .home-groups__badge{display:flex;align-items:center;gap:18px;padding-bottom:26px;border-bottom:2px solid var(--ink)}
  .home-groups__badge strong{color:var(--rust);font-size:68px;letter-spacing:-.06em;line-height:.8}.home-groups__badge span{max-width:130px;font-size:13px;font-weight:950;letter-spacing:1px;line-height:1.1;text-transform:uppercase}
  .home-groups__callouts ul{margin:0;padding:0;list-style:none}.home-groups__callouts li{display:grid;grid-template-columns:36px 1fr;gap:12px;padding:15px 0;border-bottom:1px solid #cfc2b1;font-size:14px;font-weight:900;text-transform:uppercase}.home-groups__callouts li span{color:var(--rust);font-size:10px;letter-spacing:1px}
  @media(max-width:900px){.home-groups__inner{grid-template-columns:1fr}.home-groups__callouts{max-width:600px;margin-right:14px}}
  @media(max-width:640px){.home-groups__callouts{padding:27px}.home-groups__actions{align-items:stretch;flex-direction:column}.home-groups__actions .button{width:100%}.home-groups__text-link{padding:8px 0}}
{% endstylesheet %}
