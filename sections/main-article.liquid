<article><header class="page-hero"><div class="page-width--narrow"><span class="eyebrow">{{ blog.title }} · {{ article.published_at | date: '%B %d, %Y' }}</span><h1 class="display-title">{{ article.title }}</h1></div></header>{% if article.image %}<div class="page-width--narrow content-section">{{ article.image | image_url: width: 1800 | image_tag: widths: '700,1100,1500,1800', alt: article.title }}</div>{% endif %}<div class="content-section page-width--narrow"><div class="rte">{{ article.content }}</div></div></article>
{% schema %}{"name":"Article","settings":[]}{% endschema %}
