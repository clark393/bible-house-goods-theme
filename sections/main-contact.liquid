<section><header class="page-hero"><div class="page-width--narrow"><span class="eyebrow">We'd love to hear from you</span><h1 class="display-title">{{ page.title }}</h1>{% if page.content != blank %}<div class="rte">{{ page.content }}</div>{% endif %}</div></header><div class="content-section page-width--narrow">
  {% form 'contact', class: 'contact-form' %}{% if form.posted_successfully? %}<p>Thanks for reaching out. We'll be in touch soon.</p>{% endif %}{{ form.errors | default_errors }}<div class="field-grid"><div><label class="field-label" for="ContactName">Name</label><input id="ContactName" name="contact[name]" autocomplete="name"></div><div><label class="field-label" for="ContactEmail">Email</label><input id="ContactEmail" type="email" name="contact[email]" autocomplete="email" required></div></div><div><label class="field-label" for="ContactPhone">Phone</label><input id="ContactPhone" type="tel" name="contact[phone]" autocomplete="tel"></div><div><label class="field-label" for="ContactMessage">Message</label><textarea id="ContactMessage" name="contact[body]" required></textarea></div><button class="button" type="submit">Send message</button>{% endform %}
</div></section>
{% schema %}{"name":"Contact page","settings":[]}{% endschema %}
