{% if section.settings.show %}
  <div class="ticker" aria-label="Announcement">
    <div class="ticker__track">
      {% for i in (1..2) %}
        <strong>{{ section.settings.text_1 }}</strong><b aria-hidden="true">✦</b><span>{{ section.settings.text_2 }}</span><b aria-hidden="true">✦</b><span>{{ section.settings.text_3 }}</span><b aria-hidden="true">✦</b>
      {% endfor %}
    </div>
  </div>
{% endif %}
{% schema %}
{"name":"Announcement ticker","settings":[{"type":"checkbox","id":"show","label":"Show ticker","default":true},{"type":"text","id":"text_1","label":"Highlighted message","default":"Free shipping on all Bible Band orders"},{"type":"text","id":"text_2","label":"Message two","default":"Keep God's Word Close"},{"type":"text","id":"text_3","label":"Message three","default":"Scripture · Prayer · Devotion"}]}
{% endschema %}
