<a class="product-card" href="{{ product.url }}">
  <div class="product-card__image">
    {% if product.featured_image != blank %}
      {{ product.featured_image | image_url: width: 900 | image_tag: widths: '240,360,540,720,900', loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
    {% unless product.available %}<span class="badge">Sold out</span>{% endunless %}
    {% if product.compare_at_price > product.price %}<span class="badge">Sale</span>{% endif %}
  </div>
  <div class="product-card__info">
    <h3>{{ product.title }}</h3>
    <div class="product-card__price">
      {% if product.price_varies %}From {% endif %}{{ product.price | money }}
      {% if product.compare_at_price > product.price %}<s>{{ product.compare_at_price | money }}</s>{% endif %}
    </div>
  </div>
</a>
