{% doc %}
Renders social sharing controls for a product.

@param {product} product - The product to share.
@param {string} share_url - The canonical product URL.

@example
{% render 'product-share', product: product, share_url: canonical_url %}
{% enddoc %}

{% liquid
  assign share_title = product.title
  unless share_title contains '™'
    assign share_title = share_title | replace: 'Bible Band', 'Bible Band™' | replace: 'BibleBand', 'BibleBand™'
  endunless
  assign encoded_url = share_url | url_encode
  assign encoded_title = share_title | url_encode
  assign share_text = 'products.share.message' | t: product: share_title
  assign encoded_text = share_text | url_encode
  if product.featured_image
    assign share_image = product.featured_image | image_url: width: 1200
    assign encoded_image = share_image | url_encode
  endif
%}

<aside class="product-share" data-product-share data-share-url="{{ share_url | escape }}" data-share-title="{{ share_title | escape }}" data-share-text="{{ share_text | escape }}" aria-labelledby="ProductShare-{{ product.id }}">
  <div class="product-share__head">
    <h2 id="ProductShare-{{ product.id }}">{{ 'products.share.heading' | t }}</h2>
    <p>{{ 'products.share.copy' | t }}</p>
  </div>
  <div class="product-share__buttons">
    <button class="product-share__button product-share__button--primary" type="button" data-native-share>
      <svg class="product-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M18 16.1c-.8 0-1.5.3-2 .8l-7.1-4.1c.1-.3.1-.5.1-.8s0-.5-.1-.8L16 7c.6.6 1.3.9 2 .9a3 3 0 1 0-3-3c0 .3 0 .5.1.8L8 9.8A3 3 0 1 0 8 14l7.1 4.1c-.1.2-.1.5-.1.7a3 3 0 1 0 3-2.7Z" fill="currentColor"/></svg>
      <span>{{ 'products.share.share_button' | t }}</span>
    </button>
    <a class="product-share__button" href="https://www.facebook.com/sharer/sharer.php?u={{ encoded_url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ 'products.share.facebook_label' | t }}">
      <svg class="product-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M13.7 21v-8h2.7l.4-3h-3.1V8.1c0-.9.3-1.6 1.6-1.6H17V3.8c-.3 0-1.3-.1-2.4-.1-2.4 0-4.1 1.5-4.1 4.2V10H7.8v3h2.7v8h3.2Z" fill="currentColor"/></svg>
      <span>Facebook</span>
    </a>
    <a class="product-share__button" href="https://twitter.com/intent/tweet?text={{ encoded_text }}&amp;url={{ encoded_url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ 'products.share.x_label' | t }}">
      <svg class="product-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M18.9 3H22l-6.8 7.8 8 10.2h-6.3l-5-6.4-5.6 6.4H3.2l7.3-8.4L2.8 3h6.4l4.5 5.8L18.9 3Zm-1.1 16h1.7L8.3 4.9H6.5L17.8 19Z" fill="currentColor"/></svg>
      <span>X</span>
    </a>
    {% if encoded_image %}
      <a class="product-share__button" href="https://pinterest.com/pin/create/button/?url={{ encoded_url }}&amp;media={{ encoded_image }}&amp;description={{ encoded_text }}" target="_blank" rel="noopener noreferrer" aria-label="{{ 'products.share.pinterest_label' | t }}">
        <svg class="product-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 3a9 9 0 0 0-3.3 17.4c-.1-1.5 0-3.2.4-4.6l1.2-5s-.3-.8-.3-2c0-1.9 1.1-3.3 2.5-3.3 1.2 0 1.7.9 1.7 2 0 1.2-.8 3-1.2 4.6-.3 1.4.7 2.5 2.1 2.5 2.5 0 4.5-2.7 4.5-6.6 0-3.4-2.5-5.9-6.1-5.9-4.2 0-6.6 3.1-6.6 6.4 0 1.2.5 2.5 1 3.2.1.1.1.3.1.5l-.4 1.5c-.1.5-.5.6-.9.4-2-1-3.2-3.8-3.2-6.1C3.5 4.9 6.7 1 12.9 1c5 0 8.9 3.5 8.9 8.2 0 4.9-3.1 8.8-7.4 8.8-1.4 0-2.8-.8-3.3-1.7l-.9 3.4c-.3 1.4-1.2 3.1-1.8 4.1.9.3 1.8.4 2.8.4a9 9 0 1 0 .8-18Z" fill="currentColor"/></svg>
        <span>Pinterest</span>
      </a>
    {% endif %}
    <a class="product-share__button" href="mailto:?subject={{ encoded_title }}&amp;body={{ encoded_text }}%20{{ encoded_url }}" aria-label="{{ 'products.share.email_label' | t }}">
      <svg class="product-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M3 5h18v14H3V5Zm2 2v.4l7 5.3 7-5.3V7H5Zm14 10V9.9l-7 5.3-7-5.3V17h14Z" fill="currentColor"/></svg>
      <span>{{ 'products.share.email' | t }}</span>
    </a>
    <button class="product-share__button" type="button" data-copy-share>
      <svg class="product-share__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M8 7V5c0-1.1.9-2 2-2h8c1.1 0 2 .9 2 2v8c0 1.1-.9 2-2 2h-2v4c0 1.1-.9 2-2 2H6c-1.1 0-2-.9-2-2v-8c0-1.1.9-2 2-2h2Zm2 0h4c1.1 0 2 .9 2 2v4h2V5h-8v2Zm4 2H6v10h8V9Z" fill="currentColor"/></svg>
      <span>{{ 'products.share.copy_link' | t }}</span>
    </button>
  </div>
  <p class="product-share__status" data-share-status data-copied="{{ 'products.share.copied' | t | escape }}" aria-live="polite"></p>
</aside>
