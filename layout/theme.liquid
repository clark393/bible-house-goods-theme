<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.deep_black }}">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <title>{{ page_title }}{% if current_tags %} – {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} – Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
    {%- liquid
      assign social_share_image = settings.social_share_image
      if social_share_image == blank
        assign social_share_image = all_products['the-bible-band'].featured_image
      endif
      assign social_share_title = page_title | default: shop.name
      assign social_share_description = page_description | default: shop.description | strip_html
    -%}
    <meta property="og:site_name" content="{{ shop.name | escape }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ social_share_title | escape }}">
    <meta property="og:type" content="website">
    {% if social_share_description != blank %}<meta property="og:description" content="{{ social_share_description | escape }}">{% endif %}
    {% if social_share_image != blank %}
      <meta property="og:image" content="https:{{ social_share_image | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="https:{{ social_share_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta name="twitter:card" content="summary_large_image">
      <meta name="twitter:image" content="https:{{ social_share_image | image_url: width: 1200 }}">
    {% endif %}
    <meta name="twitter:title" content="{{ social_share_title | escape }}">
    {% if social_share_description != blank %}<meta name="twitter:description" content="{{ social_share_description | escape }}">{% endif %}
    {{ content_for_header }}
    {%- liquid
      assign heading_font_bold = settings.heading_font | font_modify: 'weight', 'bolder'
      assign body_font_bold = settings.body_font | font_modify: 'weight', 'bolder'
    -%}
    <style>
      {{ settings.heading_font | font_face: font_display: 'swap' }}
      {% if heading_font_bold %}{{ heading_font_bold | font_face: font_display: 'swap' }}{% endif %}
      {{ settings.body_font | font_face: font_display: 'swap' }}
      {% if body_font_bold %}{{ body_font_bold | font_face: font_display: 'swap' }}{% endif %}
    </style>
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    <style>
      :root {
        --ink: {{ settings.deep_black }};
        --cream: {{ settings.cream }};
        --tan: {{ settings.tan }};
        --brown: {{ settings.brown }};
        --rust: {{ settings.rust }};
        --gold: {{ settings.gold }};
        --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
        --font-heading-style: {{ settings.heading_font.style }};
        --font-heading-weight: {{ settings.heading_font.weight }};
        --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
        --font-body-style: {{ settings.body_font.style }};
        --font-body-weight: {{ settings.body_font.weight }};
        --font-body-size: {{ settings.body_font_size }}px;
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#MainContent">Skip to content</a>
    {% sections 'header-group' %}
    <main id="MainContent" tabindex="-1">{{ content_for_layout }}</main>
    {% sections 'footer-group' %}
  </body>
</html>
